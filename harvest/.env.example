# 위키 데이터 업로드 설정
WIKI_DATA_DIR=/Users/sandeulpark/bigdata
WIKI_BUCKET_NAME=wiki-data

# MinIO 연결 설정  
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_REGION=us-east-1

# 로그 설정
LOG_FILE_PATH=upload.log
LOG_LEVEL=INFO

# 업로드 성능 설정
MULTIPART_THRESHOLD=26214400  # 25MB in bytes
MULTIPART_CHUNKSIZE=26214400  # 25MB in bytes
MAX_CONCURRENCY=10
USE_THREADS=true

# 재시도 설정
MAX_RETRIES=3
RETRY_DELAY=5  # seconds